{
    "name": "wp-seopress/wp-seopress",
    "description": "WordPress SEO plugin with metadata, sitemaps, social tags, and performance features.",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=7.4",
        "google/apiclient": "^2.16",
        "google/auth": "^1.37.1",
        "matthiasmullie/minify": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "test:unit": "\"./vendor/bin/phpunit\" --testsuite unit --colors=always --configuration ./phpunit.xml.dist",
        "run-tests": [
            "@test:unit"
        ],
        "post-install-cmd": [
            "composer dump-autoload"
        ],
        "post-update-cmd": [
            "Google\\Task\\Composer::cleanup",
            "composer dump-autoload"
        ]
    },
    "autoload": {
        "psr-4": {
            "SEOPress\\": "src/"
        }
    },
    "extra": {
        "google/apiclient-services": [
            "Indexing"
        ]
    },
    "license": "MIT",
    "authors": [
        {
            "name": "SEOPress",
            "email": "contact@seopress.org"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
